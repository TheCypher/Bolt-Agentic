# --- Node / pnpm ---
node_modules/
.pnpm-debug.log*
pnpm-debug.log*
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# lockfiles (we use pnpm)
package-lock.json
yarn.lock

# --- Build outputs ---
dist/
build/
.out/
.esbuild/
*.tsbuildinfo
tsconfig.tsbuildinfo

# Per-package dists (monorepo)
packages/*/dist/
packages/*/*/dist/

# --- Next.js (test apps / examples) ---
.next/
.next-static/
out/
.vercel/

# --- Coverage / tests ---
coverage/
*.snap

# --- Caches / temp ---
.cache/
tmp/
temp/

# --- Env files ---
.env
.env.*.local
.env.local

# --- OS / Editors ---
.DS_Store
Thumbs.db
.idea/
.vscode/*
!.vscode/extensions.json   # keep recommended extensions if you add them
!.vscode/settings.json     # keep shared minimal settings if you add them

# --- Misc ---
*.log
*.tgz
*.orig
*.rej
