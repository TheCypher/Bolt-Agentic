{
  "name": "@bolt-ai/react",
  "version": "1.0.0",
  "description": "React bindings and hooks for Bolt AI agents.",
  "license": "MIT",
  "author": "Bolt AI",
  "repository": {
    "type": "git",
    "url": "https://github.com/TheCypher/Bolt-Agentic.git"
  },
  "homepage": "https://github.com/TheCypher/Bolt-Agentic#readme",
  "bugs": {
    "url": "https://github.com/TheCypher/Bolt-Agentic/issues"
  },
  "keywords": [
    "ai",
    "agents",
    "react",
    "typescript",
    "bolt"
  ],
  "type": "module",
  "main": "dist/index.cjs",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=18.17"
  },
  "publishConfig": {
    "access": "public"
  },
  "peerDependencies": {
    "react": "^18 || ^19",
    "react-dom": "^18 || ^19"
  },
  "devDependencies": {
    "@types/react": "^18.3.24",
    "@types/react-dom": "^18.3.7",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "tsup": "^8.0.0",
    "typescript": "^5.5.0",
    "rimraf": "^6.0.1"
  },
  "scripts": {
    "build": "tsup src/index.ts --dts --format esm,cjs --tsconfig tsconfig.json",
    "clean": "rimraf dist"
  }
}
