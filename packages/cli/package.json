{
  "name": "@bolt-ai/cli",
  "version": "1.0.0",
  "description": "CLI for running Bolt Markdown agents with native providers.",
  "license": "MIT",
  "author": "Bolt AI",
  "repository": {
    "type": "git",
    "url": "https://github.com/TheCypher/Bolt-Agentic.git"
  },
  "type": "module",
  "bin": {
    "bolt": "dist/index.js"
  },
  "main": "dist/index.cjs",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": ["dist"],
  "engines": {
    "node": ">=20.0.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@bolt-ai/agents": "workspace:*",
    "@bolt-ai/core": "workspace:*",
    "@bolt-ai/providers-gemini": "workspace:*",
    "@bolt-ai/providers-openai": "workspace:*",
    "@bolt-ai/providers-groq": "workspace:*"
  },
  "devDependencies": {
    "rimraf": "^6.0.1",
    "tsup": "^8.5.0",
    "typescript": "^5.5.0",
    "vitest": "^1.6.0"
  },
  "scripts": {
    "build": "tsup src/index.ts --dts --format esm,cjs --tsconfig tsconfig.json",
    "clean": "rimraf dist"
  }
}
