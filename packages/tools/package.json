{
  "name": "@bolt-ai/tools",
  "version": "0.1.0",
  "description": "Built-in tool implementations for Bolt AI agents.",
  "license": "MIT",
  "author": "Bolt AI",
  "repository": {
    "type": "git",
    "url": "https://github.com/TheCypher/Bolt-Agentic.git"
  },
  "homepage": "https://github.com/TheCypher/Bolt-Agentic#readme",
  "bugs": {
    "url": "https://github.com/TheCypher/Bolt-Agentic/issues"
  },
  "keywords": [
    "ai",
    "agents",
    "tools",
    "workflows",
    "bolt"
  ],
  "type": "module",
  "main": "dist/index.cjs",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": ["dist"],
  "engines": {
    "node": ">=18.17"
  },
  "publishConfig": {
    "access": "public"
  },
  "peerDependencies": {
    "@bolt-ai/core": ">=0.1.0"
  },
  "peerDependenciesMeta": {
    "@bolt-ai/core": {
      "optional": false
    }
  },
  "dependencies": {
    "undici": "^6.19.8"
  },
  "devDependencies": {
    "@bolt-ai/core": "workspace:*",
    "tsup": "^8.5.0",
    "typescript": "^5.5.0",
    "rimraf": "^6.0.1"
  },
  "scripts": {
    "build": "tsup src/index.ts --dts --format esm,cjs --tsconfig tsconfig.json",
    "clean": "rimraf dist"
  }
}
