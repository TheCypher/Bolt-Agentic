  "files": ["dist"],
  "engines": {
    "node": ">=18.17"
  },
  "publishConfig": {
    "access": "public"
  },
  "peerDependencies": {
    "@bolt-ai/core": ">=0.0.14"
  },
  "peerDependenciesMeta": {
    "@bolt-ai/core": { "optional": false }
  },
  "dependencies": {
    "groq-sdk": "^0.32.0"
  },
  "devDependencies": {
    "@bolt-ai/core": "workspace:*",
    "tsup": "^8.5.0",
    "typescript": "^5.5.0",
    "rimraf": "^6.0.1"
  },
  "scripts": {
    "build": "tsup src/index.ts --dts --format esm,cjs --tsconfig tsconfig.json",
    "clean": "rimraf dist"
  }
}
