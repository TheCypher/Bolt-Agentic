{
  "name": "@bolt-ai/providers-groq",
  "version": "0.0.14",
  "description": "Groq model provider adapter for Bolt AI agents.",
  "license": "MIT",
  "author": "Bolt AI",
  "repository": {
    "type": "git",
    "url": "https://github.com/TheCypher/Bolt-Agentic.git"
  },
  "homepage": "https://github.com/TheCypher/Bolt-Agentic#readme",
  "bugs": {
    "url": "https://github.com/TheCypher/Bolt-Agentic/issues"
  },
  "keywords": [
    "ai",
    "agents",
    "groq",
    "providers",
    "bolt"
  ],
  "type": "module",
  "main": "dist/index.cjs",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
